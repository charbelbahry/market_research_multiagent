# Engine configuration
USE_REAL_CREW=true
REQUEST_TIMEOUT_SECONDS=240

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
