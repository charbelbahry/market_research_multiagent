APP_NAME="AI product research analyzer"

# OpenRouter configuration
CHEAP_MODEL_NAME="openrouter/openai/gpt-4o-mini"
STRONG_MODEL_NAME="openrouter/nvidia/nemotron-3-ultra-550b-a55b:free"
